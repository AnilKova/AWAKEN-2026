      <button class="fb-submit" id="fbSubmit" onclick="submitFeedback()">Send Feedback ✦</button>
      <div class="fb-status" id="fbStatus"></div>
    </div>
  </div>
</div>

<style>@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}</style>
<script>

// ── COUNTDOWN ──
function updateCountdown(){
  const target=new Date('2026-05-21T09:00:00+05:30');
  const now=new Date();const diff=target-now;
  if(diff<=0){document.querySelector('.countdown-wrap').innerHTML='<div class="cd-eyebrow" style="font-size:1.2rem;color:var(--lime);">✦ AWAKEN 2026 Is LIVE! ✦</div>';return;}
  const d=Math.floor(diff/86400000),h=Math.floor((diff%86400000)/3600000),m=Math.floor((diff%3600000)/60000),s=Math.floor((diff%60000)/1000);
  document.getElementById('days').textContent=String(d).padStart(3,'0');
  document.getElementById('hours').textContent=String(h).padStart(2,'0');
  document.getElementById('minutes').textContent=String(m).padStart(2,'0');
  document.getElementById('seconds').textContent=String(s).padStart(2,'0');
}
updateCountdown();setInterval(updateCountdown,1000);

// ── FAQ ──
function toggleFaq(btn){
  const item=btn.closest('.faq-item');const was=item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
  if(!was)item.classList.add('open');
}

// ── SCHEDULE TABS ──
function switchDay(btn,id){
  document.querySelectorAll('.day-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(id).classList.add('active');
}

// ── MOBILE NAV ──
function toggleMobileNav(btn){
  const nav=document.getElementById('mobileNav');
  const open=nav.style.display==='flex';
  nav.style.display=open?'none':'flex';
  btn.textContent=open?'☰':'✕';
}
function closeMobileNav(){
  document.getElementById('mobileNav').style.display='none';
  document.querySelector('.nav-hamburger').textContent='☰';
}
document.addEventListener('scroll',closeMobileNav,{passive:true});

// ── REGISTRATION FORM ──
const GOOGLE_SCRIPT_URL='YOUR_GOOGLE_APPS_SCRIPT_URL_HERE';
const FEEDBACK_SCRIPT_URL='YOUR_FEEDBACK_GOOGLE_APPS_SCRIPT_URL_HERE';

document.getElementById('regForm').addEventListener('submit',async function(e){
  e.preventDefault();
  const data={
    firstName:document.getElementById('firstName').value.trim(),
    lastName:document.getElementById('lastName').value.trim(),
    phone:document.getElementById('phone').value.trim(),
    age:document.getElementById('age').value.trim(),
    email:document.getElementById('email').value.trim(),
    church:document.getElementById('church').value.trim(),
    city:document.getElementById('city').value.trim(),
    days:document.getElementById('days').value,
    role:document.getElementById('role').value,
    hearAbout:document.getElementById('hearAbout').value,
    prayer:document.getElementById('prayer').value.trim(),
    timestamp:new Date().toISOString(),
  };
  const required=['firstName','lastName','phone','age','church','city','days','role'];
  for(const k of required){if(!data[k]){showRegStatus('error','⚠ Please fill in all required fields.');return;}}
  if(!document.getElementById('consent').checked){showRegStatus('error','⚠ Please confirm your attendance.');return;}
  if(data.phone.replace(/\D/g,'').length<10){showRegStatus('error','⚠ Please enter a valid phone number.');return;}

  const btn=document.getElementById('regSubmit');
  btn.disabled=true;btn.textContent='Submitting…';
  showRegStatus('loading','⏳ Saving your registration…');

  if(GOOGLE_SCRIPT_URL==='YOUR_GOOGLE_APPS_SCRIPT_URL_HERE'){
    setTimeout(()=>{
      showRegStatus('success','🎉 Registered! <strong>'+data.firstName+' '+data.lastName+'</strong> from '+data.church+'.<br>See you at Abundant Life Fellowship Church, Mancherial!<br><br><small>To enable live Google Sheets: paste your Apps Script Web App URL into <code>GOOGLE_SCRIPT_URL</code>.</small>');
      document.getElementById('regForm').reset();
      btn.disabled=false;btn.textContent='✦ Register Now — It\'s Free ✦';
      console.log('Registration:',data);
    },1000);
    return;
  }
  try{
    await fetch(GOOGLE_SCRIPT_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
    showRegStatus('success','🎉 Registered! See you at AWAKEN 2026, <strong>'+data.firstName+'</strong>!');
    document.getElementById('regForm').reset();
  }catch(err){showRegStatus('error','❌ Something went wrong. Please try again.');}
  finally{btn.disabled=false;btn.textContent='✦ Register Now — It\'s Free ✦';}
});

function showRegStatus(type,msg){
  const s=document.getElementById('regStatus');
  s.className='frm-status '+type;s.innerHTML=msg;
  s.scrollIntoView({behavior:'smooth',block:'nearest'});
}

// ── FEEDBACK MODAL ──
let fbRating=0;
const starLabels=['','Not great','Could be better','It was OK','Really good','Amazing! 🎉'];

function openFeedback(){document.getElementById('fbOverlay').classList.add('open');document.body.style.overflow='hidden';}
function closeFeedback(){document.getElementById('fbOverlay').classList.remove('open');document.body.style.overflow='';}
function handleOverlayClick(e){if(e.target===document.getElementById('fbOverlay'))closeFeedback();}

function setRating(n){
  fbRating=n;
  document.querySelectorAll('.fb-star').forEach((s,i)=>{s.classList.toggle('active',i<n);});
  document.getElementById('fbStarLabel').textContent=starLabels[n];
}

function toggleCategory(btn){btn.classList.toggle('selected');}

async function submitFeedback(){
  const msg=document.getElementById('fbMsg').value.trim();
  if(!msg){showFbStatus('error','⚠ Please share your feedback message.');return;}

  const cats=[...document.querySelectorAll('.fb-cat.selected')].map(b=>b.textContent).join(', ');
  const data={
    name:document.getElementById('fbName').value.trim()||'Anonymous',
    church:document.getElementById('fbChurch').value.trim(),
    rating:fbRating||'Not rated',
    categories:cats||'General',
    message:msg,
    recommend:document.getElementById('fbRecommend').value,
    timestamp:new Date().toISOString(),
  };

  const btn=document.getElementById('fbSubmit');
  btn.disabled=true;btn.textContent='Sending…';
  showFbStatus('loading','⏳ Submitting feedback…');

  if(FEEDBACK_SCRIPT_URL==='YOUR_FEEDBACK_GOOGLE_APPS_SCRIPT_URL_HERE'){
    setTimeout(()=>{
      showFbStatus('success','🙏 Thank you for your feedback! We read every response and it helps us grow.');
      console.log('Feedback:',data);
      setTimeout(closeFeedback,3000);
    },900);
    btn.disabled=false;btn.textContent='Send Feedback ✦';
    return;
  }
  try{
    await fetch(FEEDBACK_SCRIPT_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
    showFbStatus('success','🙏 Thank you! Your feedback has been received.');
    setTimeout(closeFeedback,3000);
  }catch(err){showFbStatus('error','❌ Could not send. Please try again.');}
  finally{btn.disabled=false;btn.textContent='Send Feedback ✦';}
}

function showFbStatus(type,msg){
  const s=document.getElementById('fbStatus');
  s.className='fb-status '+type;s.innerHTML=msg;
}

document.addEventListener('keydown',e=>{if(e.key==='Escape')closeFeedback();});
</script>
</body>
</html>
